    "sudo hostnamectl set-hostname ngs-testing-vm.biochem.mpg.de\n",
    "\n",
    "# Verify the change\n",
    "hostnamectl status\n",
    "\n",
    "```\n",
    "\n",
    "```{bash}\n",
    "nslookup ngs-testing-vm.biochem.mpg.de\n",
